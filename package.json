{
  "name": "cardinal-gate-react-native",
  "main": "expo-router/entry",
  "version": "1.0.0",
  "scripts": {
    "start": "expo start",
    "android": "expo run:android",
    "build:android": "eas build --profile development --platform android --local",
    "ios": "expo run:ios",
    "web": "expo start --web",
    "test": "jest --watchAll",
    "lint": "expo lint",
    "coverage": "jest --coverage"
  },
  "jest": {
    "preset": "jest-expo",
    "setupFiles": [
      "<rootDir>/__tests__/setup.ts"
    ],
    "testPathIgnorePatterns": [
      "<rootDir>/__tests__/setup.ts",
      "<rootDir>/__tests__/helpers/"
    ],
    "moduleNameMapper": {
      "\\.(css)$": "<rootDir>/__tests__/helpers/css-mock.js"
    },
    "transformIgnorePatterns": [
      "/node_modules/(?!(.pnpm|react-native|@react-native|@react-native-community|expo|@expo|@expo-google-fonts|react-navigation|@react-navigation|@sentry/react-native|native-base|@rn-primitives|class-variance-authority|lucide-react-native|polished))",
      "/node_modules/react-native-reanimated/plugin/"
    ]
  },
  "dependencies": {
    "@react-native-async-storage/async-storage": "2.2.0",
    "@react-native-masked-view/masked-view": "^0.3.2",
    "@react-navigation/drawer": "^7.9.4",
    "@react-navigation/native": "^7.0.14",
    "@rn-primitives/checkbox": "^1.2.0",
    "@rn-primitives/dialog": "^1.2.0",
    "@rn-primitives/portal": "^1.3.0",
    "@rn-primitives/select": "^1.2.0",
    "@rn-primitives/slot": "^1.2.0",
    "@tanstack/react-query": "^5.90.21",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "expo": "^55.0.0",
    "expo-constants": "~55.0.7",
    "expo-device": "~55.0.9",
    "expo-haptics": "~55.0.8",
    "expo-image": "~55.0.5",
    "expo-linear-gradient": "~55.0.8",
    "expo-linking": "~55.0.7",
    "expo-router": "~55.0.3",
    "expo-screen-orientation": "~55.0.8",
    "expo-secure-store": "~55.0.8",
    "expo-sharing": "~55.0.11",
    "expo-splash-screen": "~55.0.10",
    "expo-status-bar": "~55.0.4",
    "lucide-react-native": "^0.577.0",
    "nativewind": "^4.2.2",
    "react": "19.2.0",
    "react-dom": "19.2.0",
    "react-native": "0.83.2",
    "react-native-gesture-handler": "^2.30.0",
    "react-native-pager-view": "^8.0.0",
    "react-native-reanimated": "4.2.1",
    "react-native-safe-area-context": "~5.6.2",
    "react-native-screens": "~4.23.0",
    "react-native-svg": "15.15.3",
    "react-native-tab-view": "^4.2.2",
    "react-native-web": "^0.21.2",
    "react-native-worklets": "0.7.2",
    "reanimated-color-picker": "^4.2.0",
    "tailwind-merge": "^3.5.0",
    "tailwindcss": "^3.4.19",
    "tailwindcss-animate": "^1.0.7",
    "zustand": "^5.0.11"
  },
  "devDependencies": {
    "@babel/core": "^7.29.0",
    "@babel/plugin-transform-export-namespace-from": "^7.25.9",
    "@dev-plugins/react-query": "^0.4.0",
    "@stylistic/eslint-plugin": "^5.10.0",
    "@testing-library/react-native": "^13.3.3",
    "@types/jest": "29.5.14",
    "@types/react": "^19.2.14",
    "eslint": "^9.39.4",
    "eslint-config-expo": "^55.0.0",
    "eslint-plugin-expo": "^1.0.0",
    "eslint-plugin-react-hooks": "^7.0.1",
    "expo-dev-client": "~55.0.10",
    "jest": "~29.7.0",
    "jest-expo": "^55.0.9",
    "test-renderer": "^0.15.0",
    "typescript": "^5.9.3"
  },
  "private": true
}
